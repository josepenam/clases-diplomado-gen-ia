# Copy this file to `.env` and fill in your real keys. Never commit the real `.env`.
ANTHROPIC_API_KEY=your-anthropic-api-key

# LangSmith (para tracing + evals de la sesión 3.6). Opcional: sin esto el
# agente corre igual, solo que sin trazas.
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=analista-economico-cl
LANGSMITH_TRACING=true
